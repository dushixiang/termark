  {
    "enabled": true,
    "pattern": "\\b(?:[0-9a-fA-F]{4}-){2}[0-9a-fA-F]{4}\\b|\\b(?:[0-9a-fA-F]{2}:){5}[0-9a-fA-F]{2}\\b",
    "note": "MAC 地址",
    "color": "#bd93f9"
  },
  {
    "enabled": true,
    "pattern": "\\b(?:GigabitEthernet|XGigabitEthernet|10GE|40GE|100GE|Eth-Trunk|Vlanif|LoopBack)\\s*[0-9/]+\\b",
